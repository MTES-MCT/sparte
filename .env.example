ENVIRONMENT=local
SECRET=CREATE_A_SECRET_KEY
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost,django,host.docker.internal
DOMAIN_URL=http://localhost:8080/

# Base de données
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=PICK_A_PASSWORD
POSTGRES_HOST=db
DATABASE_URL=postgis://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:5432/$POSTGRES_DB
DB_LOGGING_LEVEL=WARNING

# Redis
SCALINGO_REDIS_URL=redis://redis:6379/0

# S3 (versitygw local)
AWS_ACCESS_KEY_ID=localaccess
AWS_SECRET_ACCESS_KEY=localsecret
AWS_STORAGE_BUCKET_NAME=sparte-local
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://s3:7070
AWS_LOCATION=local
LOCAL_FILE_DIRECTORY=public_data/local_data

# Email
EMAIL_ENGINE=local
API_KEY_SENDINBLUE=ASK_A_MAINTAINER
EMAIL_SMTP_KEY=ASK_A_MAINTAINER
EMAIL_HOST_USER=YOUR_EMAIL
DEFAULT_FROM_EMAIL=YOUR_EMAIL

# Crisp (chat support)
CRISP_WEBSITE_ID=ASK_A_MAINTAINER
CRISP_ACTIVATED=0
CRISP_WEBHOOK_SECRET_KEY=CREATE_A_SECRET_KEY
CRISP_API_IDENTIFIER=
CRISP_API_KEY=

# Analytics
MATOMO_ACTIVATE=0
GOOGLE_ADWORDS_ACTIVATE=0

# Highcharts / Export
HIGHCHART_SERVER=https://highcharts-export.osc-fr1.scalingo.io
EXPORT_SERVER_URL=http://export-server:3000
EXPORT_BASE_URL=http://django:8080

# Notifications
MATTERMOST_WEBHOOK=https://mattermost.incubateur.net/hooks/uak581f8bidyxp5td67rurj5sh
ALERT_DIAG_MEDIUM=both
ALERT_DIAG_EMAIL_RECIPIENTS=YOUR_EMAIL
ALERT_DIAG_MATTERMOST_RECIPIENTS=@YOUR_MATTERMOST_USERNAME

# Sécurité
USE_SRI=0
USE_CSP=1
TWO_FACTOR_ENABLED=0

# ProConnect (OIDC)
PROCONNECT_DOMAIN=ASK_A_MAINTAINER
PROCONNECT_CLIENT_ID=ASK_A_MAINTAINER
PROCONNECT_SECRET=ASK_A_MAINTAINER
